PORT=3001
NODE_ENV=development
JWT_SECRET=pingalert-dev-secret-key-123456789
JWT_EXPIRES_IN=7d

# Database Connection (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pingalert

# Redis Connection (BullMQ)
REDIS_URL=redis://localhost:6379

# Rate Limiting (900000ms = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQ=100

# Monitor Check Retries
PING_RETRY_COUNT=3
PING_RETRY_DELAY_SEC=5

# Worker Concurrency Settings
PING_CONCURRENCY=50
ALERT_CONCURRENCY=10

# SMTP / Email Alerts (Optional - if omitted, email is only logged in DB)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@pingalert.com
